7. Middleware

Description:
Middleware runs before route handlers.

Use case:
Logging, request IDs, basic request preprocessing.

@Injectable()
export class LoggerMiddleware implements NestMiddleware {
  use(req: Request, res: Response, next: NextFunction) {
    console.log(`${req.method} ${req.originalUrl}`);
    next();
  }
}
export class AppModule implements NestModule {
  configure(consumer: MiddlewareConsumer) {
    consumer.apply(LoggerMiddleware).forRoutes('*');
  }
}

Nest middleware runs before the route handler and has access to the request, response, and next() function.  

⸻

8. Guards

Description:
Guards decide whether a request is allowed to continue.

Use case:
Authentication, authorization, role checks.

@Injectable()
export class AuthGuard implements CanActivate {
  canActivate(context: ExecutionContext): boolean {
    const request = context.switchToHttp().getRequest();
    return Boolean(request.headers.authorization);
  }
}
@UseGuards(AuthGuard)
@Get('profile')
getProfile() {
  return { message: 'Protected route' };
}

Guards run after middleware but before interceptors and pipes, making them ideal for authorization.  

⸻

9. Interceptors

Description:
Interceptors wrap request handling before and after controller execution.

Use case:
Logging, response mapping, caching, timing, exception transformation.

@Injectable()
export class ResponseInterceptor implements NestInterceptor {
  intercept(context: ExecutionContext, next: CallHandler) {
    return next.handle().pipe(
      map(data => ({
        success: true,
        data,
      })),
    );
  }
}
@UseInterceptors(ResponseInterceptor)
@Get()
findAll() {
  return this.usersService.findAll();
}

Nest interceptors can add logic before or after method execution, transform responses, transform exceptions, or override behavior.  


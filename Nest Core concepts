18. Dynamic Modules

Description:
Dynamic modules allow configurable reusable modules.

Use case:
Shared logging, payments, notification modules.

@Module({})
export class LoggerModule {
  static register(prefix: string): DynamicModule {
    return {
      module: LoggerModule,
      providers: [
        {
          provide: 'LOGGER_PREFIX',
          useValue: prefix,
        },
      ],
      exports: ['LOGGER_PREFIX'],
    };
  }
}


14. Database Integration with TypeORM

Description:
NestJS can integrate with relational databases using TypeORM.

Use case:
CRUD with PostgreSQL, MySQL, SQL Server.

@Entity()
export class User {
  @PrimaryGeneratedColumn()
  id: number;
  @Column()
  name: string;
  @Column({ unique: true })
  email: string;
}
@Injectable()
export class UsersService {
  constructor(
    @InjectRepository(User)
    private readonly repo: Repository<User>,
  ) {}
  findAll() {
    return this.repo.find();
  }
  create(dto: CreateUserDto) {
    return this.repo.save(dto);
  }
}

